# ==========================================
# 微信小程序特定忽略
# ==========================================
# 忽略私有配置（包含你的 AppID 和本地编译设置）
project.private.config.json

# 忽略小程序自动生成的编译后目录 # 1. 忽略所有层级的依赖库（会自动匹配 search/miniprogram/node_modules）
miniprogram_npm/
node_modules/

# 忽略小程序开发者工具产生的临时文件
.metadata/
*.wxss.map
*.wxml.map

# ==========================================
# 编程语言与依赖
# ==========================================
# 忽略依赖库
package-lock.json
# 如果你希望在不同机器同步依赖版本，可以取消注释下面这行
# !package-lock.json

# 忽略编译后的 JavaScript (如果是从 TS 编译来的)
# *.js
# 但要保留小程序必要的配置文件
!app.js
!project.config.js

# ==========================================
# 编辑器与系统
# ==========================================
.vscode/
.DS_Store
Thumbs.db
*.log

# ==========================================
# 搜索逻辑/数据处理相关 (可选)
# ==========================================
# 如果你有大型的原始数据 Excel 或临时备份，可以忽略
# *.xlsx
# *.bak

# ==========================================
# 开发工具相关
# ==========================================
.vscode/
# 如果你使用了 typings 且它是自动生成的，也可以考虑忽略
miniprogram/typings/*