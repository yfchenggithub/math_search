<view wx:if="{{section}}" class="{{rootClass}}">
  <view class="section-shell">
    <view class="section-header">
      <view
        class="section-title copyable-text"
        data-copy-text="{{section.title}}"
        bindlongpress="onTextLongPress"
      >{{section.title}}</view>
    </view>

    <view class="section-body">
      <block wx:for="{{section.blocks}}" wx:key="id" wx:for-item="block">
        <view
          wx:if="{{block.kind === 'text'}}"
          class="section-text copyable-text"
          data-copy-text="{{block.text || block.html}}"
          bindlongpress="onTextLongPress"
        >
          <view class="rich-copy">
            <rich-text nodes="{{block.html || block.text}}"></rich-text>
          </view>
        </view>

        <view
          wx:if="{{block.kind === 'mixed'}}"
          class="section-text copyable-text"
          data-copy-text="{{block.text || block.html}}"
          bindlongpress="onTextLongPress"
        >
          <mixed-content-renderer
            html="{{block.html || ''}}"
            segments="{{block.segments || []}}"
          ></mixed-content-renderer>
        </view>

        <view wx:if="{{block.kind === 'bullet'}}" class="section-bullet">
          <view class="bullet-dot"></view>
          <view
            class="bullet-text copyable-text"
            data-copy-text="{{block.text || block.html}}"
            bindlongpress="onTextLongPress"
          >
            <mixed-content-renderer
              wx:if="{{block.segments && block.segments.length}}"
              html="{{block.html || ''}}"
              segments="{{block.segments}}"
            ></mixed-content-renderer>
            <view wx:else class="rich-copy">
              <rich-text nodes="{{block.html || block.text}}"></rich-text>
            </view>
          </view>
        </view>

        <view wx:if="{{block.kind === 'formula'}}" class="formula-card formula-card--align-{{block.formulaAlign || 'center'}}">
          <scroll-view scroll-x="{{!zoomActive}}" class="formula-scroll" enhanced="{{true}}">
            <view class="formula-track">
              <rich-text class="formula-rich" nodes="{{block.formulaHtml}}"></rich-text>
            </view>
          </scroll-view>
        </view>

        <view wx:if="{{block.kind === 'math_image'}}" class="math-image-block">
          <scroll-view
            scroll-x
            enhanced="{{true}}"
            show-scrollbar="{{false}}"
            class="math-image-scroll"
          >
            <image
              wx:if="{{block.imageUrl && !block.imageLoadFailed}}"
              class="math-image"
              src="{{block.imageUrl}}"
              mode="widthFix"
              lazy-load="{{true}}"
              style="width: {{block.displayWidthRpx}}rpx;"
              data-block-index="{{index}}"
              data-node-path="{{block.__path}}"
              data-url="{{block.imageUrl}}"
              binderror="onMathImageError"
              bindlongpress="onMathImageLongPress"
            />
          </scroll-view>

          <view
            wx:if="{{!block.imageUrl || block.imageLoadFailed}}"
            class="math-image-fallback"
          >
            <text class="math-image-fallback-title">公式图片暂时无法显示</text>
            <text wx:if="{{block.alt}}" class="math-image-fallback-alt">{{block.alt}}</text>
          </view>
        </view>

        <view wx:if="{{block.kind === 'theorem'}}" class="theorem-card">
          <view
            wx:if="{{block.titleHtml}}"
            class="theorem-title copyable-text"
            data-copy-text="{{block.title || block.titleHtml}}"
            bindlongpress="onTextLongPress"
          >
            <view class="rich-copy">
              <rich-text nodes="{{block.titleHtml}}"></rich-text>
            </view>
          </view>
          <view
            wx:elif="{{block.title}}"
            class="theorem-title copyable-text"
            data-copy-text="{{block.title}}"
            bindlongpress="onTextLongPress"
          >
            {{block.title}}
          </view>

          <block wx:if="{{block.descParts && block.descParts.length}}">
            <block wx:for="{{block.descParts}}" wx:key="index" wx:for-item="part">
              <view
                wx:if="{{part.kind === 'html'}}"
                class="theorem-desc copyable-text"
                data-copy-text="{{part.html}}"
                bindlongpress="onTextLongPress"
              >
                <view class="rich-copy">
                  <rich-text nodes="{{part.html}}"></rich-text>
                </view>
              </view>

              <view wx:if="{{part.kind === 'math_image' && part.image}}" class="math-image-block theorem-math-image-block">
                <scroll-view
                  scroll-x
                  enhanced="{{true}}"
                  show-scrollbar="{{false}}"
                  class="math-image-scroll"
                >
                  <image
                    wx:if="{{part.image.imageUrl && !part.image.imageLoadFailed}}"
                    class="math-image"
                    src="{{part.image.imageUrl}}"
                    mode="widthFix"
                    lazy-load="{{true}}"
                    style="width: {{part.image.displayWidthRpx}}rpx;"
                    data-node-path="{{part.image.__path}}"
                    data-url="{{part.image.imageUrl}}"
                    binderror="onMathImageError"
                    bindlongpress="onMathImageLongPress"
                  />
                </scroll-view>

                <view
                  wx:if="{{!part.image.imageUrl || part.image.imageLoadFailed}}"
                  class="math-image-fallback"
                >
                  <text class="math-image-fallback-title">公式图片暂时无法显示</text>
                  <text wx:if="{{part.image.alt}}" class="math-image-fallback-alt">{{part.image.alt}}</text>
                </view>
              </view>
            </block>
          </block>

          <view
            wx:elif="{{block.descLeadHtml || block.descHtml}}"
            class="theorem-desc copyable-text"
            data-copy-text="{{block.desc || block.descLeadHtml || block.descHtml}}"
            bindlongpress="onTextLongPress"
          >
            <view class="rich-copy">
              <rich-text nodes="{{block.descLeadHtml || block.descHtml}}"></rich-text>
            </view>
          </view>
          <view
            wx:elif="{{block.desc && !block.descTailHtml && !block.descLeadHtml}}"
            class="theorem-desc copyable-text"
            data-copy-text="{{block.desc}}"
            bindlongpress="onTextLongPress"
          >
            {{block.desc}}
          </view>
          <view wx:if="{{block.formulaImages && block.formulaImages.length}}" class="theorem-math-image-list">
            <view
              wx:for="{{block.formulaImages}}"
              wx:key="__path"
              wx:for-item="formulaImage"
              class="math-image-block theorem-math-image-block"
            >
              <scroll-view
                scroll-x
                enhanced="{{true}}"
                show-scrollbar="{{false}}"
                class="math-image-scroll"
              >
                <image
                  wx:if="{{formulaImage.imageUrl && !formulaImage.imageLoadFailed}}"
                  class="math-image"
                  src="{{formulaImage.imageUrl}}"
                  mode="widthFix"
                  lazy-load="{{true}}"
                  style="width: {{formulaImage.displayWidthRpx}}rpx;"
                  data-node-path="{{formulaImage.__path}}"
                  data-url="{{formulaImage.imageUrl}}"
                  binderror="onMathImageError"
                  bindlongpress="onMathImageLongPress"
                />
              </scroll-view>

              <view
                wx:if="{{!formulaImage.imageUrl || formulaImage.imageLoadFailed}}"
                class="math-image-fallback"
              >
                <text class="math-image-fallback-title">公式图片暂时无法显示</text>
                <text wx:if="{{formulaImage.alt}}" class="math-image-fallback-alt">
                  {{formulaImage.alt}}
                </text>
              </view>
            </view>
          </view>

          <view wx:elif="{{block.formulaHtml}}" class="formula-card inner formula-card--align-{{block.formulaAlign || 'center'}}">
            <scroll-view scroll-x="{{!zoomActive}}" class="formula-scroll" enhanced="{{true}}">
              <view class="formula-track">
                <rich-text class="formula-rich" nodes="{{block.formulaHtml}}"></rich-text>
              </view>
            </scroll-view>
          </view>
          <view
            wx:if="{{block.descTailHtml}}"
            class="theorem-desc copyable-text"
            data-copy-text="{{block.descTailHtml}}"
            bindlongpress="onTextLongPress"
          >
            <view class="rich-copy">
              <rich-text nodes="{{block.descTailHtml}}"></rich-text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
