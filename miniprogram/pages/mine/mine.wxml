<view class="mine-page">
  <navigation-bar
    title="我的"
    back="{{false}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="mine-page__container">
    <view class="mine-user-card">
      <block wx:if="{{isLoggedIn}}">
        <view class="mine-user-card__main">
          <image
            class="mine-user-card__avatar"
            src="{{userInfo.avatarUrl || defaultAvatar}}"
            mode="aspectFill"
          />
          <view class="mine-user-card__content">
            <text class="mine-user-card__nickname">{{userInfo.nickname || '微信用户'}}</text>
            <text class="mine-user-card__meta">
              已收藏 {{favoriteCount}} 条结论
            </text>
          </view>
        </view>

        <button class="mine-user-card__logout-btn" bindtap="handleLogoutTap">
          退出登录
        </button>
      </block>

      <block wx:else>
        <view class="mine-user-card__main">
          <image
            class="mine-user-card__avatar"
            src="{{defaultAvatar}}"
            mode="aspectFill"
          />
          <view class="mine-user-card__content">
            <text class="mine-user-card__nickname">立即登录</text>
            <text class="mine-user-card__meta">登录后可同步收藏与浏览记录</text>
          </view>
        </view>

        <button
          class="mine-user-card__login-btn"
          bindtap="handleLoginTap"
          loading="{{isLoggingIn}}"
          disabled="{{isLoggingIn}}"
        >
          立即登录
        </button>
      </block>
    </view>

    <view class="mine-section mine-section--primary">
      <view class="mine-section__header">
        <text class="mine-section__title">我的内容</text>
      </view>

      <view class="mine-list mine-list--primary">
        <view class="mine-list-item mine-list-item--highlight" bindtap="handleFavoritesTap">
          <view class="mine-list-item__left">
            <text class="mine-list-item__label">我的收藏</text>
          </view>
          <view class="mine-list-item__right">
            <text class="mine-list-item__value">共 {{favoriteCount}} 条</text>
            <text class="mine-list-item__arrow">></text>
          </view>
        </view>

        <view class="mine-list-item" bindtap="handleHistoryTap">
          <view class="mine-list-item__left">
            <text class="mine-list-item__label">最近浏览</text>
          </view>
          <view class="mine-list-item__right">
            <text class="mine-list-item__arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <view
      class="mine-section mine-section--secondary"
      bindlongpress="handleDevSupportLongPress"
    >
      <view class="mine-section__header">
        <text class="mine-section__title">开发与支持</text>
      </view>

      <view class="mine-list mine-list--secondary">
        <view class="mine-list-item mine-list-item--with-subtitle" bindtap="handleOfficialAccountTap">
          <view class="mine-list-item__left mine-list-item__left--stacked">
            <text class="mine-list-item__label">开发者公众号</text>
            <text class="mine-list-item__desc">{{officialAccountDesc}}</text>
          </view>
          <view class="mine-list-item__right">
            <text class="mine-list-item__arrow">></text>
          </view>
        </view>

        <label class="mine-list-item" for="mine-feedback-trigger">
          <view class="mine-list-item__left">
            <text class="mine-list-item__label">意见反馈</text>
          </view>
          <view class="mine-list-item__right">
            <text class="mine-list-item__arrow">></text>
          </view>
          <button
            id="mine-feedback-trigger"
            class="mine-list-item__feedback-trigger-hidden"
            open-type="feedback"
            hover-class="none"
            bindtap="onFeedbackTap"
          ></button>
        </label>

        <block wx:if="{{showRuntimeLogEntry}}">
          <view class="mine-list-item" bindtap="handleConclusionRequestAdminTap">
            <view class="mine-list-item__left">
              <text class="mine-list-item__label">求结论管理</text>
            </view>
            <view class="mine-list-item__right">
              <text class="mine-list-item__arrow">></text>
            </view>
          </view>

          <view class="mine-list-item" bindtap="handleRuntimeLogsTap">
            <view class="mine-list-item__left">
              <text class="mine-list-item__label">运行日志</text>
            </view>
            <view class="mine-list-item__right">
              <text class="mine-list-item__arrow">></text>
            </view>
          </view>
        </block>

        <view class="mine-list-item" bindtap="handleSettingsTap">
          <view class="mine-list-item__left">
            <text class="mine-list-item__label">设置</text>
          </view>
          <view class="mine-list-item__right">
            <text class="mine-list-item__arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <view class="mine-footer">
      <text class="mine-footer__link" bindtap="handleUserAgreementTap">用户协议</text>
      <text class="mine-footer__divider"> / </text>
      <text class="mine-footer__link" bindtap="handlePrivacyTap">隐私政策</text>
    </view>
  </view>

  <view
    wx:if="{{officialAccountModalVisible}}"
    class="mine-modal-layer"
    catchtouchmove="noop"
  >
    <view class="mine-modal-card" catchtap="noop">
      <view class="mine-modal-head">
        <text class="mine-modal-title">开发者公众号</text>
        <text class="mine-modal-desc">关注公众号，获取产品更新、使用帮助和问题反馈。</text>
      </view>

      <image
        wx:if="{{officialAccountQrVisible && officialAccountQrImage}}"
        class="mine-modal-qr"
        src="{{officialAccountQrImage}}"
        mode="aspectFill"
        binderror="handleOfficialAccountQrError"
      />

      <view class="mine-modal-account">
        <text class="mine-modal-account__label">公众号名称</text>
        <text class="mine-modal-account__name">{{officialAccountName}}</text>
      </view>

      <view class="mine-modal-actions">
        <button
          class="mine-modal-btn mine-modal-btn--primary"
          bindtap="handleCopyOfficialAccountTap"
        >
          复制公众号名称
        </button>
        <button
          class="mine-modal-btn mine-modal-btn--ghost"
          bindtap="closeOfficialAccountModal"
        >
          我知道了
        </button>
      </view>
    </view>
  </view>

  <auth-status-toast-host
    visible="{{authStatusToastVisible}}"
    type="{{authStatusToastType}}"
    title="{{authStatusToastTitle}}"
    message="{{authStatusToastMessage}}"
    retryable="{{authStatusToastRetryable}}"
    closable="{{authStatusToastClosable}}"
    bindretry="handleAuthStatusRetryTap"
    bindclose="handleAuthStatusCloseTap"
  ></auth-status-toast-host>
</view>
