<view class="page">
  <navigation-bar
    title="{{homeCopy.title}}"
    back="{{false}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="header">
    <view class="title">{{homeCopy.title}}</view>
    <view class="sub">{{homeCopy.subtitle}}</view>
  </view>

  <view class="search-card">
    <view class="search-title">{{homeCopy.searchTitle}}</view>

    <view class="search-box">
      <input
        class="search-input"
        value="{{query}}"
        bindinput="onInput"
        bindconfirm="onConfirm"
        confirm-type="search"
        focus="{{focus}}"
        placeholder="{{homeCopy.searchPlaceholder}}"
      />

      <view wx:if="{{showClear}}" class="clear-btn" bindtap="onClear">
        ×
      </view>
    </view>

    <view class="search-hint">{{homeCopy.searchPlaceholder}}</view>
  </view>

  <view wx:if="{{query && suggestions.length > 0}}" class="suggest-box">
    <block wx:for="{{suggestions}}" wx:key="index">
      <view
        class="suggest-item"
        data-text="{{item.text}}"
        bindtap="onSuggestionTap"
      >
        <text class="suggest-text">{{item.text}}</text>
        <text class="suggest-id">{{item.id}}</text>
      </view>
    </block>
  </view>

  <scroll-view scroll-x class="tabs">
    <view
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{quickFilters}}"
      wx:key="key"
      bindtap="onTabTap"
      data-tab="{{item.key}}"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <scroll-view scroll-y class="list">
    <view wx:if="{{loading}}" class="state-box state-loading">
      搜索中...
    </view>

    <view wx:if="{{!loading && errorMessage}}" class="state-box state-error">
      {{errorMessage}}
    </view>

    <view wx:if="{{!query && !loading && !errorMessage && results.length === 0}}" class="empty-state">
      <view class="empty-title">{{homeCopy.emptyTitle}}</view>
      <view class="empty-subtitle">{{homeCopy.emptySubtitle}}</view>
    </view>

    <view wx:if="{{query && !loading && !errorMessage && results.length === 0}}" class="empty-state">
      <view class="empty-title">{{homeCopy.noResultTitle}}</view>
      <view class="empty-subtitle">{{homeCopy.noResultSubtitle}}</view>
    </view>

    <view
      class="card"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="onDetailTap"
      data-id="{{item.id}}"
    >
      <view class="card-top">
        <view class="card-title">
          <block wx:for="{{item.titleSegments}}" wx:key="index">
            <text class="{{item.highlight ? 'hl' : ''}}">
              {{item.text}}
            </text>
          </block>
        </view>

        <view class="score">评分 {{item.score}}</view>
      </view>

      <view class="formula">
        <scroll-view scroll-x class="formula-scroll" enhanced="{{true}}">
          <rich-text class="formula-rich" nodes="{{item.formulaHtml}}"></rich-text>
        </scroll-view>
      </view>

      <view class="tags">
        <text class="tag">分类：{{item.category}}</text>
        <text class="tag">难度：{{item.level}}</text>
        <text class="tag">频率：{{item.freq}}</text>
        <text class="tag red">热度：{{item.recentScore}}</text>
      </view>

      <view class="usage">
        {{item.usage}}
      </view>

      <view class="footer">
        <view
          class="detail-btn"
          catchtap="onDetailTap"
          data-id="{{item.id}}"
        >
          查看详情
        </view>
      </view>
    </view>
  </scroll-view>
</view>
