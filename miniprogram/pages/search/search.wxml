<view class="page">
  <view
    class="header"
    style="padding-top: calc({{statusBarHeight}}px + 20rpx);"
  >
    <view class="title">数学搜索</view>
    <view class="sub">
      共 {{total}} 条索引，热点考点 {{hotCount}} 条
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <view class="num">{{learned}}</view>
      <view class="label">已入索引</view>
    </view>

    <view class="stat-item">
      <view class="num">{{rate1}}%</view>
      <view class="label">高热度占比</view>
    </view>

    <view class="stat-item">
      <view class="num">{{rate2}}%</view>
      <view class="label">高频考点占比</view>
    </view>
  </view>

  <view class="search-box">
    <text class="search-prefix">检索</text>
    <input
      class="search-input"
      value="{{query}}"
      bindinput="onInput"
      bindconfirm="onConfirm"
      confirm-type="search"
      focus="{{focus}}"
      placeholder="搜索：柯西 / sin / lnx / 对数平均值"
    />

    <view wx:if="{{showClear}}" class="clear-btn" bindtap="onClear">
      X
    </view>
  </view>

  <view wx:if="{{query && suggestions.length > 0}}" class="suggest-box">
    <block wx:for="{{suggestions}}" wx:key="index">
      <view
        class="suggest-item"
        data-text="{{item.text}}"
        bindtap="onSuggestionTap"
      >
        <text class="suggest-text">{{item.text}}</text>
        <text class="suggest-id">{{item.id}}</text>
      </view>
    </block>
  </view>

  <scroll-view scroll-x class="tabs">
    <view
      class="tab {{activeTab === item ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="*this"
      bindtap="onTabTap"
      data-tab="{{item}}"
    >
      {{item}}
    </view>
  </scroll-view>

  <view class="sort">
    当前排序：term / prefix 聚合得分优先，其次参考条目 rank
  </view>

  <view wx:if="{{query && debugInfo}}" class="debug-card">
    <view class="debug-head" bindtap="onToggleDebug">
      <text class="debug-title">搜索调试</text>
      <text class="debug-toggle">{{debugExpanded ? '收起' : '展开'}}</text>
    </view>

    <view wx:if="{{debugExpanded}}" class="debug-body">
      <view class="debug-metrics">
        <view class="debug-metric">
          <text class="debug-label">规范化</text>
          <text class="debug-value">{{debugInfo.normalizedQuery}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">term 命中</text>
          <text class="debug-value">{{debugInfo.termHitCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">prefix 命中</text>
          <text class="debug-value">{{debugInfo.prefixHitCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">建议候选</text>
          <text class="debug-value">{{debugInfo.suggestionHitCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">结果数</text>
          <text class="debug-value">{{debugInfo.resultCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">回退建议</text>
          <text class="debug-value">{{debugInfo.fallbackUsed ? '是' : '否'}}</text>
        </view>
      </view>

      <view class="debug-section">
        <view class="debug-section-title">Lookup Tokens</view>
        <view class="debug-chip-row">
          <text
            wx:for="{{debugInfo.lookupTokens}}"
            wx:key="*this"
            class="debug-chip"
          >
            {{item}}
          </text>
        </view>
      </view>

      <view wx:if="{{debugInfo.topSuggestions.length > 0}}" class="debug-section">
        <view class="debug-section-title">建议候选</view>
        <block wx:for="{{debugInfo.topSuggestions}}" wx:key="index">
          <view class="debug-line">
            <text class="debug-line-main">{{item.text}}</text>
            <text class="debug-line-side">{{item.id}} / {{item.score}}</text>
          </view>
        </block>
      </view>

      <view wx:if="{{debugInfo.topMatches.length > 0}}" class="debug-section">
        <view class="debug-section-title">Top Hits</view>
        <block wx:for="{{debugInfo.topMatches}}" wx:key="id">
          <view class="debug-hit">
            <view class="debug-hit-title">{{item.id}} · {{item.title}}</view>
            <view class="debug-hit-meta">score {{item.score}} · {{item.matchedFieldsLabel}}</view>
            <view class="debug-hit-meta">{{item.reasonSummary}}</view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="list">
    <view wx:if="{{query && results.length === 0}}" class="empty-state">
      没有命中结果，试试更短的关键词或点上面的建议词。
    </view>

    <view
      class="card"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="onDetailTap"
      data-id="{{item.id}}"
    >
      <view class="card-top">
        <view class="card-title">
          <block wx:for="{{item.titleSegments}}" wx:key="index">
            <text class="{{item.highlight ? 'hl' : ''}}">
              {{item.text}}
            </text>
          </block>
        </view>

        <view class="score">搜索 {{item.score}}</view>
      </view>

      <view class="formula">
        <scroll-view scroll-x class="formula-scroll" enhanced="{{true}}">
          <rich-text class="formula-rich" nodes="{{item.formulaHtml}}"></rich-text>
        </scroll-view>
      </view>

      <view class="tags">
        <text class="tag">分类：{{item.category}}</text>
        <text class="tag">难度：{{item.level}}</text>
        <text class="tag">频率：{{item.freq}}</text>
        <text class="tag red">考分：{{item.recentScore}}</text>
      </view>

      <view class="usage">
        {{item.usage}}
      </view>

      <view class="footer">
        <view
          class="detail-btn"
          catchtap="onDetailTap"
          data-id="{{item.id}}"
        >
          查看详情
        </view>
      </view>
    </view>
  </scroll-view>
</view>
