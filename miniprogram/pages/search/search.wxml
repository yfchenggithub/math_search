<view class="page">
  <navigation-bar
    title="{{homeCopy.title}}"
    back="{{false}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  >
    <!-- <button slot="right" class="nav-share-btn" open-type="share">
      分享
    </button> -->
  </navigation-bar>

  <view class="header">
    <view class="title">{{homeCopy.title}}</view>
    <view class="sub">{{homeCopy.subtitle}}</view>
  </view>

  <view class="search-card">
    <view class="search-title">{{homeCopy.searchTitle}}</view>

    <view class="search-box">
      <input
        class="search-input"
        value="{{query}}"
        bindinput="onInput"
        bindconfirm="onConfirm"
        confirm-type="search"
        focus="{{focus}}"
        placeholder="{{homeCopy.searchPlaceholder}}"
      />

      <view wx:if="{{showClear}}" class="clear-btn" bindtap="onClear">
        ×
      </view>
    </view>

    <view class="search-hint" bindtap="onConclusionRequestEntryTap">
      没搜到想要的结论？<text class="search-hint-link">点此告诉我们</text>，24小时内更新。
    </view>
  </view>

  <view wx:if="{{query && suggestions.length > 0}}" class="suggest-box">
    <block wx:for="{{suggestions}}" wx:key="index">
      <view
        class="suggest-item"
        data-text="{{item.text}}"
        data-id="{{item.id}}"
        data-module="{{item.module}}"
        bindtap="onSuggestionTap"
      >
        <text class="suggest-text">{{item.text}}</text>
        <text class="suggest-id">{{item.id}}</text>
      </view>
    </block>
  </view>

  <view
    wx:if="{{showPdfEntitlementCard}}"
    class="pdf-entitlement-card {{pdfEntitlement.unlocked ? 'pdf-entitlement-card-unlocked' : ''}}"
  >
    <view class="pdf-entitlement-title">{{pdfEntitlementTitle}}</view>
    <view class="pdf-entitlement-subtitle">{{pdfEntitlementSubtitle}}</view>
    <view class="pdf-entitlement-description">{{pdfEntitlementDescription}}</view>
    <view class="pdf-entitlement-hint">{{pdfEntitlementHint}}</view>
    <button
      class="pdf-entitlement-action"
      loading="{{pdfEntitlementActionBusy}}"
      disabled="{{pdfEntitlementActionBusy}}"
      bindtap="onPdfEntitlementActionTap"
    >
      {{pdfEntitlementActionText}}
    </button>
  </view>

  <scroll-view scroll-x class="tabs">
    <view
      class="tab {{activeTab === item.key ? 'active' : ''}}"
      wx:for="{{quickFilters}}"
      wx:key="key"
      bindtap="onTabTap"
      data-tab="{{item.key}}"
    >
      {{item.label}}
    </view>
  </scroll-view>

  <scroll-view scroll-y class="list" scroll-top="{{listScrollTop}}">
    <view wx:if="{{loading}}" class="state-box state-loading">
      搜索中...
    </view>

    <view wx:if="{{!loading && errorMessage}}" class="state-box state-error">
      {{errorMessage}}
    </view>

    <block wx:if="{{!query && !loading && !errorMessage && results.length === 0}}">
      <block wx:if="{{homeRecommendSections.length > 0}}">
        <block wx:for="{{homeRecommendSections}}" wx:key="key" wx:for-item="section">
          <view class="recommend-section">
            <view class="recommend-header">
              <view class="recommend-title">{{section.title}}</view>
              <view class="recommend-subtitle">{{section.subtitle}}</view>
            </view>

            <block wx:for="{{section.items}}" wx:key="id" wx:for-item="recommend">
              <conclusion-card
                item-id="{{recommend.id}}"
                title="{{recommend.title}}"
                summary="{{recommend.summary}}"
                tags="{{recommend.tags}}"
                entry="recommend_card"
                section="{{section.key}}"
                module="{{recommend.module}}"
                has-pdf="{{recommend.hasPdf}}"
                bind:cardtap="onDetailTap"
              ></conclusion-card>
            </block>
          </view>
        </block>
      </block>

      <view wx:else class="empty-state">
        <view class="empty-title">{{homeCopy.emptyTitle}}</view>
        <view class="empty-subtitle">{{homeCopy.emptySubtitle}}</view>
      </view>
    </block>

    <view wx:if="{{query && !loading && !errorMessage && results.length === 0}}" class="empty-state">
      <view class="empty-title">{{homeCopy.noResultTitle}}</view>
      <view class="empty-subtitle">{{homeCopy.noResultSubtitle}}</view>
    </view>

    <view wx:if="{{query && !loading && !errorMessage && results.length === 0 && noResultRecommendItems.length > 0}}" class="no-result-recommend">
      <view class="no-result-recommend-title">你可以试试这些内容</view>

      <block wx:for="{{noResultRecommendItems}}" wx:key="id" wx:for-item="recommend">
        <conclusion-card
          item-id="{{recommend.id}}"
          title="{{recommend.title}}"
          summary="{{recommend.summary}}"
          tags="{{recommend.tags}}"
          compact="{{true}}"
          show-tags="{{false}}"
          entry="no_result_recommend_card"
          section="no_result"
          module="{{recommend.module}}"
          has-pdf="{{recommend.hasPdf}}"
          bind:cardtap="onDetailTap"
        ></conclusion-card>
      </block>
    </view>

    <view
      class="card"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="onDetailTap"
      data-id="{{item.id}}"
      data-entry="search_result_card"
      data-module="{{item.module}}"
    >
      <view class="card-top">
        <view class="card-title">
          <block wx:for="{{item.titleSegments}}" wx:key="index">
            <text class="{{item.highlight ? 'hl' : ''}}">
              {{item.text}}
            </text>
          </block>
        </view>

        <view class="score">评分 {{item.score}}</view>
      </view>

      <view class="formula">
        <scroll-view scroll-x class="formula-scroll" enhanced="{{true}}">
          <rich-text class="formula-rich" nodes="{{item.formulaHtml}}"></rich-text>
        </scroll-view>
      </view>

      <view class="tags">
        <text class="tag">分类：{{item.category}}</text>
        <text class="tag">难度：{{item.level}}</text>
        <text class="tag">频率：{{item.freq}}</text>
        <text class="tag red">热度：{{item.recentScore}}</text>
      </view>

      <view class="usage">
        {{item.usage}}
      </view>

      <view class="footer">
        <view
          class="detail-btn"
          catchtap="onDetailTap"
          data-id="{{item.id}}"
          data-entry="search_result_button"
          data-module="{{item.module}}"
        >
          查看详情
        </view>
      </view>
    </view>
  </scroll-view>

  <view
    wx:if="{{conclusionRequestDialogVisible}}"
    class="conclusion-request-layer"
    catchtouchmove="noop"
    bindtap="onConclusionRequestCancel"
  >
    <view class="conclusion-request-card" catchtap="noop">
      <view class="conclusion-request-title">求结论</view>
      <view class="conclusion-request-subtitle">
        告诉我们你想找什么，后续会优先补齐高频需求。
      </view>

      <view class="conclusion-request-field">
        <view class="conclusion-request-label">搜索词</view>
        <input
          class="conclusion-request-input"
          value="{{conclusionRequestQuery}}"
          bindinput="onConclusionRequestQueryInput"
          maxlength="40"
          placeholder="例如：柯西不等式"
          focus="{{conclusionRequestQueryFocus}}"
        />
      </view>

      <view class="conclusion-request-field">
        <view class="conclusion-request-label">补充说明</view>
        <textarea
          class="conclusion-request-textarea"
          value="{{conclusionRequestNote}}"
          bindinput="onConclusionRequestNoteInput"
          maxlength="{{conclusionRequestNoteMaxLength}}"
          placeholder="可以写题型、场景，或你想看的结论"
          show-confirm-bar="{{false}}"
          auto-height="{{false}}"
          focus="{{conclusionRequestNoteFocus}}"
        ></textarea>
        <view class="conclusion-request-counter">
          {{conclusionRequestNoteLength}}/{{conclusionRequestNoteMaxLength}}
        </view>
      </view>

      <view class="conclusion-request-actions">
        <button
          class="conclusion-request-btn conclusion-request-btn-ghost"
          bindtap="onConclusionRequestCancel"
        >
          取消
        </button>
        <button
          class="conclusion-request-btn conclusion-request-btn-primary"
          loading="{{conclusionRequestSubmitting}}"
          disabled="{{conclusionRequestSubmitting}}"
          bindtap="onConclusionRequestSubmit"
        >
          提交
        </button>
      </view>
    </view>
  </view>
</view>
