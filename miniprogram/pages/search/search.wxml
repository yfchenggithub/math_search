<view class="page">
  <navigation-bar
    title="高中数学二级结论搜索"
    back="{{false}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="header">
    <view class="title">Math Search</view>
    <view class="sub">
      {{total}} indexed items, {{hotCount}} hot points
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <view class="num">{{learned}}</view>
      <view class="label">Indexed</view>
    </view>

    <view class="stat-item">
      <view class="num">{{rate1}}%</view>
      <view class="label">Hot Ratio</view>
    </view>

    <view class="stat-item">
      <view class="num">{{rate2}}%</view>
      <view class="label">Exam Ratio</view>
    </view>
  </view>

  <view class="search-box">
    <text class="search-prefix">Search</text>
    <input
      class="search-input"
      value="{{query}}"
      bindinput="onInput"
      bindconfirm="onConfirm"
      confirm-type="search"
      focus="{{focus}}"
      placeholder="Try: Cauchy / sin / lnx / log mean"
    />

    <view wx:if="{{showClear}}" class="clear-btn" bindtap="onClear">
      X
    </view>
  </view>

  <view wx:if="{{query && suggestions.length > 0}}" class="suggest-box">
    <block wx:for="{{suggestions}}" wx:key="index">
      <view
        class="suggest-item"
        data-text="{{item.text}}"
        bindtap="onSuggestionTap"
      >
        <text class="suggest-text">{{item.text}}</text>
        <text class="suggest-id">{{item.id}}</text>
      </view>
    </block>
  </view>

  <scroll-view scroll-x class="tabs">
    <view
      class="tab {{activeTab === item ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="*this"
      bindtap="onTabTap"
      data-tab="{{item}}"
    >
      {{item}}
    </view>
  </scroll-view>

  <view class="sort">
    Sort: term/prefix score first, then rank
  </view>

  <view wx:if="{{query && debugInfo}}" class="debug-card">
    <view class="debug-head" bindtap="onToggleDebug">
      <text class="debug-title">Search Debug</text>
      <text class="debug-toggle">{{debugExpanded ? 'Collapse' : 'Expand'}}</text>
    </view>

    <view wx:if="{{debugExpanded}}" class="debug-body">
      <view class="debug-metrics">
        <view class="debug-metric">
          <text class="debug-label">Normalized</text>
          <text class="debug-value">{{debugInfo.normalizedQuery}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">Term Hits</text>
          <text class="debug-value">{{debugInfo.termHitCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">Prefix Hits</text>
          <text class="debug-value">{{debugInfo.prefixHitCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">Suggestions</text>
          <text class="debug-value">{{debugInfo.suggestionHitCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">Result Count</text>
          <text class="debug-value">{{debugInfo.resultCount}}</text>
        </view>

        <view class="debug-metric">
          <text class="debug-label">Local Fallback</text>
          <text class="debug-value">{{debugInfo.fallbackUsed ? 'Yes' : 'No'}}</text>
        </view>
      </view>

      <view class="debug-section">
        <view class="debug-section-title">Lookup Tokens</view>
        <view class="debug-chip-row">
          <text
            wx:for="{{debugInfo.lookupTokens}}"
            wx:key="*this"
            class="debug-chip"
          >
            {{item}}
          </text>
        </view>
      </view>

      <view wx:if="{{debugInfo.topSuggestions.length > 0}}" class="debug-section">
        <view class="debug-section-title">Top Suggestions</view>
        <block wx:for="{{debugInfo.topSuggestions}}" wx:key="index">
          <view class="debug-line">
            <text class="debug-line-main">{{item.text}}</text>
            <text class="debug-line-side">{{item.id}} / {{item.score}}</text>
          </view>
        </block>
      </view>

      <view wx:if="{{debugInfo.topMatches.length > 0}}" class="debug-section">
        <view class="debug-section-title">Top Hits</view>
        <block wx:for="{{debugInfo.topMatches}}" wx:key="id">
          <view class="debug-hit">
            <view class="debug-hit-title">{{item.id}} · {{item.title}}</view>
            <view class="debug-hit-meta">score {{item.score}} · {{item.matchedFieldsLabel}}</view>
            <view class="debug-hit-meta">{{item.reasonSummary}}</view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <scroll-view scroll-y class="list">
    <view wx:if="{{loading}}" class="state-box state-loading">
      Searching...
    </view>

    <view wx:if="{{!loading && errorMessage}}" class="state-box state-error">
      {{errorMessage}}
    </view>

    <view wx:if="{{query && !loading && !errorMessage && results.length === 0}}" class="empty-state">
      No result found. Try shorter keywords or pick a suggestion.
    </view>

    <view
      class="card"
      wx:for="{{results}}"
      wx:key="id"
      bindtap="onDetailTap"
      data-id="{{item.id}}"
    >
      <view class="card-top">
        <view class="card-title">
          <block wx:for="{{item.titleSegments}}" wx:key="index">
            <text class="{{item.highlight ? 'hl' : ''}}">
              {{item.text}}
            </text>
          </block>
        </view>

        <view class="score">Score {{item.score}}</view>
      </view>

      <view class="formula">
        <scroll-view scroll-x class="formula-scroll" enhanced="{{true}}">
          <rich-text class="formula-rich" nodes="{{item.formulaHtml}}"></rich-text>
        </scroll-view>
      </view>

      <view class="tags">
        <text class="tag">Category: {{item.category}}</text>
        <text class="tag">Difficulty: {{item.level}}</text>
        <text class="tag">Frequency: {{item.freq}}</text>
        <text class="tag red">Exam Score: {{item.recentScore}}</text>
      </view>

      <view class="usage">
        {{item.usage}}
      </view>

      <view class="footer">
        <view
          class="detail-btn"
          catchtap="onDetailTap"
          data-id="{{item.id}}"
        >
          View Detail
        </view>
      </view>
    </view>
  </scroll-view>
</view>
