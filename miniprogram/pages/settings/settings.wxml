<view class="settings-page">
  <navigation-bar
    title="设置"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="settings-page__container">
    <view class="settings-section">
      <view class="settings-section__header">
        <text class="settings-section__title">显示与阅读</text>
      </view>

      <view class="settings-list">
        <view class="settings-list-item">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">字号大小</text>
          </view>
          <view class="settings-list-item__right">
            <text class="settings-list-item__value">标准</text>
            <text class="settings-list-item__arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <view class="settings-section">
      <view class="settings-section__header">
        <text class="settings-section__title">搜索与记录</text>
      </view>

      <view class="settings-list">
        <view class="settings-list-item">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">保存搜索记录</text>
          </view>
          <view class="settings-list-item__right">
            <switch
              checked="{{saveSearchHistory}}"
              color="#34c759"
              bindchange="handleSaveSearchHistoryChange"
            />
          </view>
        </view>

        <view class="settings-list-item">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">清空搜索记录</text>
          </view>
          <view class="settings-list-item__right">
            <text class="settings-list-item__arrow">></text>
          </view>
        </view>

        <view class="settings-list-item">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">清空最近浏览</text>
          </view>
          <view class="settings-list-item__right">
            <text class="settings-list-item__arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <view class="settings-section">
      <view class="settings-section__header">
        <text class="settings-section__title">下载与缓存</text>
      </view>

      <view class="settings-list">
        <view class="settings-list-item">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">下载权限状态</text>
          </view>
          <view class="settings-list-item__right">
            <text class="settings-list-item__value">可下载至 21:30</text>
            <text class="settings-list-item__arrow">></text>
          </view>
        </view>

        <view class="settings-list-item settings-list-item--multiline">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">仅在 Wi-Fi 下下载高清文件</text>
          </view>
          <view class="settings-list-item__right">
            <switch
              checked="{{wifiOnlyHighResDownload}}"
              color="#34c759"
              bindchange="handleWifiOnlyHighResDownloadChange"
            />
          </view>
        </view>

        <view class="settings-list-item">
          <view class="settings-list-item__left">
            <text class="settings-list-item__label">清理本地缓存</text>
          </view>
          <view class="settings-list-item__right">
            <text class="settings-list-item__value">23.6 MB</text>
            <text class="settings-list-item__arrow">></text>
          </view>
        </view>
      </view>
    </view>

    <view class="settings-footer">
      <text class="settings-footer__version">版本 1.0.0</text>
    </view>
  </view>
</view>
