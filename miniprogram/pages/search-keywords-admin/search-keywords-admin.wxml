<view class="search-keywords-page">
  <navigation-bar
    title="搜索词语"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="search-keywords-page__container">
    <view class="search-keywords-toolbar">
      <search-box
        value="{{searchInput}}"
        placeholder="筛选搜索词"
        show-clear="{{searchInput !== '' || keyword !== ''}}"
        show-icon="{{true}}"
        bind:input="handleKeywordInput"
        bind:confirm="handleSearchConfirm"
        bind:clear="handleClearSearchTap"
      ></search-box>

      <view class="search-keywords-filter search-keywords-filter--time">
        <text class="search-keywords-filter__label">时间</text>
        <view class="search-keywords-filter__chips search-keywords-filter__chips--time">
          <button
            wx:for="{{timeRangeOptions}}"
            wx:key="value"
            class="search-keywords-filter__chip {{item.active ? 'is-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="handleTimeRangeTap"
          >
            {{item.label}}
          </button>
        </view>
      </view>

      <view class="search-keywords-filter search-keywords-filter--result">
        <text class="search-keywords-filter__label">结果</text>
        <view class="search-keywords-filter__chips search-keywords-filter__chips--result">
          <button
            wx:for="{{resultFilterOptions}}"
            wx:key="value"
            class="search-keywords-filter__chip {{item.active ? 'is-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="handleResultFilterTap"
          >
            {{item.label}}
          </button>
        </view>
      </view>

      <view class="search-keywords-filter search-keywords-filter--sort">
        <text class="search-keywords-filter__label">排序</text>
        <view class="search-keywords-sort">
          <button
            wx:for="{{sortOptions}}"
            wx:key="value"
            class="search-keywords-sort__item {{item.active ? 'is-active' : ''}}"
            data-value="{{item.value}}"
            bindtap="handleSortTap"
          >
            {{item.label}}
          </button>
        </view>
      </view>

      <view class="search-keywords-toolbar__meta">
        <text class="search-keywords-toolbar__count">{{countText}}</text>
        <view class="search-keywords-toolbar__summary">
          <text>无结果词 </text>
          <text class="search-keywords-toolbar__summary-number search-keywords-toolbar__summary-number--danger">
            {{noResultTotal}}
          </text>
          <text> 个</text>
          <text class="search-keywords-toolbar__summary-divider">|</text>
          <text>低结果词 </text>
          <text class="search-keywords-toolbar__summary-number search-keywords-toolbar__summary-number--warning">
            {{lowResultTotal}}
          </text>
          <text> 个</text>
        </view>
        <view class="search-keywords-toolbar__actions">
          <button
            class="search-keywords-toolbar__export"
            loading="{{exportingCsv}}"
            bindtap="handleExportCsvTap"
            disabled="{{loading || loadingMore || exportingCsv}}"
          >
            导出当前结果
          </button>
          <button
            class="search-keywords-toolbar__refresh"
            bindtap="handleRefreshTap"
            disabled="{{loading || loadingMore}}"
          >
            刷新
          </button>
        </view>
      </view>
    </view>

    <view wx:if="{{loading && items.length === 0}}" class="search-keywords-state">
      <text class="search-keywords-state__title">正在加载搜索词...</text>
    </view>

    <view wx:elif="{{errorMessage && items.length === 0}}" class="search-keywords-state">
      <text class="search-keywords-state__title">加载失败</text>
      <text class="search-keywords-state__desc">{{errorMessage}}</text>
      <button class="search-keywords-state__action" bindtap="handleRetryTap">
        重新加载
      </button>
    </view>

    <view wx:elif="{{items.length === 0}}" class="search-keywords-state">
      <text class="search-keywords-state__title">暂无搜索词</text>
      <text class="search-keywords-state__desc">用户提交搜索后会出现在这里</text>
    </view>

    <view wx:else class="search-keywords-list">
      <block wx:for="{{items}}" wx:key="id" wx:for-item="item">
        <view class="search-keywords-card">
          <view class="search-keywords-card__head">
            <view class="search-keywords-card__title">
              <text class="search-keywords-card__keyword">{{item.keyword || '-'}}</text>
              <view
                wx:if="{{item.showTitleNoResultBadge}}"
                class="search-keywords-card__title-badge"
              >
                无结果
              </view>
            </view>

            <view class="search-keywords-card__stats">
              <view
                wx:if="{{item.showLatestResultBadge}}"
                class="search-keywords-card__latest-result"
              >
                {{item.resultText}}
              </view>
              <view wx:else class="search-keywords-card__latest-result search-keywords-card__latest-result--muted">
                最近无结果
              </view>

              <view class="search-keywords-card__counts">
                <view class="search-keywords-card__count">{{item.countText}}</view>
                <view class="search-keywords-card__no-result-count">
                  {{item.noResultCountText}}
                </view>
              </view>
            </view>
          </view>

          <view class="search-keywords-card__meta">
            <text>最近：{{item.updatedAtText}}</text>
            <text>首次：{{item.createdAtText}}</text>
          </view>
        </view>
      </block>

      <button
        wx:if="{{hasMore}}"
        class="search-keywords-load-more"
        loading="{{loadingMore}}"
        disabled="{{loadingMore}}"
        bindtap="handleLoadMoreTap"
      >
        加载更多
      </button>
    </view>
  </view>
</view>
