<view class="request-admin-page">
  <navigation-bar
    title="求结论管理"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="request-admin-page__container">
    <view class="request-admin-toolbar">
      <scroll-view class="request-admin-filter" scroll-x="{{true}}" show-scrollbar="{{false}}">
        <view class="request-admin-filter__inner">
          <block wx:for="{{filters}}" wx:key="value" wx:for-item="filter">
            <view
              class="request-admin-filter__chip {{activeStatus === filter.value ? 'is-active' : ''}}"
              data-status="{{filter.value}}"
              bindtap="handleFilterTap"
            >
              {{filter.label}}
            </view>
          </block>
        </view>
      </scroll-view>

      <view class="request-admin-toolbar__meta">
        <text class="request-admin-toolbar__count">{{countText}}</text>
        <button
          class="request-admin-toolbar__refresh"
          bindtap="handleRefreshTap"
          disabled="{{loading || loadingMore}}"
        >
          刷新
        </button>
      </view>
    </view>

    <view wx:if="{{loading && items.length === 0}}" class="request-admin-state">
      <text class="request-admin-state__title">正在加载记录...</text>
    </view>

    <view wx:elif="{{errorMessage && items.length === 0}}" class="request-admin-state">
      <text class="request-admin-state__title">加载失败</text>
      <text class="request-admin-state__desc">{{errorMessage}}</text>
      <button class="request-admin-state__action" bindtap="handleRetryTap">
        重新加载
      </button>
    </view>

    <view wx:elif="{{items.length === 0}}" class="request-admin-state">
      <text class="request-admin-state__title">暂无求结论记录</text>
      <text class="request-admin-state__desc">用户提交后会出现在这里</text>
    </view>

    <view wx:else class="request-admin-list">
      <block wx:for="{{items}}" wx:key="id" wx:for-item="item">
        <view class="request-admin-card">
          <view class="request-admin-card__head">
            <text class="request-admin-card__query">{{item.query || '未填写搜索词'}}</text>
            <text class="request-admin-card__status request-admin-card__status--{{item.statusClass}}">
              {{item.statusText}}
            </text>
          </view>

          <text class="request-admin-card__note">{{item.noteText}}</text>

          <view class="request-admin-card__meta">
            <text>{{item.createdAtText}}</text>
            <text>{{item.entry}}</text>
            <text>{{item.resultText}}</text>
          </view>

          <view class="request-admin-card__actions">
            <block wx:for="{{item.actions}}" wx:key="status" wx:for-item="action">
              <button
                class="request-admin-card__action"
                data-id="{{item.id}}"
                data-status="{{action.status}}"
                loading="{{updatingRequestId === item.id}}"
                disabled="{{updatingRequestId > 0}}"
                catchtap="handleStatusActionTap"
              >
                {{action.label}}
              </button>
            </block>
          </view>
        </view>
      </block>

      <button
        wx:if="{{hasMore}}"
        class="request-admin-load-more"
        loading="{{loadingMore}}"
        disabled="{{loadingMore}}"
        bindtap="handleLoadMoreTap"
      >
        加载更多
      </button>
    </view>
  </view>
</view>
