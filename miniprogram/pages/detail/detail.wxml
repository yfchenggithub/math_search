<view class="page">
  <navigation-bar
    back="{{showBackButton}}"
    homeButton="{{showHomeButton}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="toolbar">
    <view class="toolbar-main">
      <view class="toolbar-title-row">
        <view
          class="toolbar-title copyable-text"
          data-copy-text="{{title}}"
          bindlongpress="onTextLongPress"
        >{{title}}</view>
        <view
          wx:if="{{viewState === 'content'}}"
          class="correction-entry-btn"
          hover-class="correction-entry-btn--hover"
          bindtap="onCorrectionEntryTap"
        >
          <text class="correction-entry-icon">!</text>
          <text>纠错</text>
        </view>
      </view>
      <view class="toolbar-sub">
        <text>{{category}}</text>
        <view class="toolbar-chip toolbar-id">ID {{id}}</view>
        <view wx:if="{{viewState === 'content' && loadDurationLabel}}" class="toolbar-chip toolbar-load-time">
          {{loadDurationLabel}}
        </view>
        <view class="toolbar-chip toolbar-scale">{{scaleLabel}}</view>
      </view>
    </view>

    <view class="toolbar-actions">
      <button bindtap="onToggleZoom" class="toolbar-btn">
        {{zoomActive ? '退出缩放' : '缩放阅读'}}
      </button>
    </view>
  </view>

  <scroll-view
    wx:if="{{viewState === 'content' && detailTocItems.length && !zoomActive}}"
    class="detail-toc"
    scroll-x
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
  >
    <view class="detail-toc-track">
      <view
        wx:for="{{detailTocItems}}"
        wx:key="key"
        wx:for-item="item"
        class="detail-toc-item {{activeDetailTocKey === item.key ? 'detail-toc-item--active' : ''}}"
        data-anchor-id="{{item.anchorId}}"
        data-key="{{item.key}}"
        bindtap="onDetailTocItemTap"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="viewer">
    <view wx:if="{{viewState === 'loading'}}" class="state-card">
      <view class="state-title">正在加载</view>
      <view class="state-desc">{{viewMessage || '请稍候...'}}</view>
    </view>

    <view wx:elif="{{viewState === 'error'}}" class="state-card">
      <view class="state-title">加载失败</view>
      <view class="state-desc">{{viewMessage || '网络异常，请稍后重试'}}</view>
      <button class="state-btn" bindtap="onRetryLoad">重试</button>
    </view>

    <view wx:elif="{{viewState === 'empty'}}" class="state-card">
      <view class="state-title">暂无内容</view>
      <view class="state-desc">{{viewMessage || '当前结论没有可展示信息'}}</view>
    </view>

    <view
      wx:else
      class="viewer-content"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    >
      <scroll-view
        class="article-scroll"
        scroll-y="{{!zoomActive}}"
        scroll-top="{{articleScrollTop}}"
        scroll-with-animation="{{articleScrollWithAnimation}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        bindscroll="onArticleScroll"
      >
        <view
          id="articleWrapper"
          class="article-wrapper"
          style="{{transformStyle}}"
        >
          <view class="article-card">
            <view class="article-header">
              <view class="article-eyebrow">{{category}}</view>
              <view class="article-id">条目 ID: {{id}}</view>
              <view
                class="article-title copyable-text"
                data-copy-text="{{title}}"
                bindlongpress="onTextLongPress"
              >{{title}}</view>
              <view
                wx:if="{{summaryHtml}}"
                class="article-summary rich-copy copyable-text"
                data-copy-text="{{summary}}"
                bindlongpress="onTextLongPress"
              >
                <rich-text nodes="{{summaryHtml}}"></rich-text>
              </view>
              <view
                wx:elif="{{summary}}"
                class="article-summary copyable-text"
                data-copy-text="{{summary}}"
                bindlongpress="onTextLongPress"
              >
                {{summary}}
              </view>

              <view
                wx:if="{{hasDifficulty || showFavoriteStatus || (tags && tags.length)}}"
                class="article-meta-chips"
              >
                <view wx:if="{{hasDifficulty}}" class="meta-chip meta-chip-difficulty">
                  难度 {{difficultyLabel}}
                </view>

                <view
                  wx:if="{{showFavoriteStatus}}"
                  class="meta-chip {{isFavorited ? 'meta-chip-favorited' : 'meta-chip-unfavorited'}}"
                >
                  {{favoriteStatusText}}
                </view>

                <view wx:for="{{tags}}" wx:key="*this" wx:for-item="tag" class="meta-chip">
                  {{tag}}
                </view>
              </view>

              <view
                wx:if="{{aliasesDisplay}}"
                class="article-alias copyable-text"
                data-copy-text="{{aliasesDisplay}}"
                bindlongpress="onTextLongPress"
              >
                别名：{{aliasesDisplay}}
              </view>
            </view>

            <view wx:if="{{longPressHintVisible}}" class="long-press-hint">
              <view class="long-press-hint__text">长按文字复制，长按公式图分享</view>
              <view class="long-press-hint__action" bindtap="dismissLongPressHint">
                知道了
              </view>
            </view>

            <view wx:if="{{coreFormulaImage || coreFormulaHtml}}" class="hero-formula">
              <view wx:if="{{coreFormulaImage}}" class="math-image-block hero-math-image-block">
                <scroll-view
                  scroll-x
                  enhanced="{{true}}"
                  show-scrollbar="{{false}}"
                  class="math-image-scroll"
                >
                  <image
                    wx:if="{{coreFormulaImage.imageUrl && !coreFormulaImage.imageLoadFailed}}"
                    class="math-image"
                    src="{{coreFormulaImage.imageUrl}}"
                    mode="widthFix"
                    lazy-load="{{true}}"
                    style="width: {{coreFormulaImage.displayWidthRpx}}rpx;"
                    data-url="{{coreFormulaImage.imageUrl}}"
                    binderror="onCoreFormulaImageError"
                    bindlongpress="onCoreFormulaImageLongPress"
                  />
                </scroll-view>

                <view
                  wx:if="{{!coreFormulaImage.imageUrl || coreFormulaImage.imageLoadFailed}}"
                  class="math-image-fallback"
                >
                  <text class="math-image-fallback-title">公式图片暂时无法显示</text>
                  <text wx:if="{{coreFormulaImage.alt}}" class="math-image-fallback-alt">
                    {{coreFormulaImage.alt}}
                  </text>
                </view>
              </view>

              <scroll-view wx:else scroll-x="{{!zoomActive}}" class="formula-scroll" enhanced="{{true}}">
                <view class="formula-track">
                  <rich-text class="formula-rich" nodes="{{coreFormulaHtml}}"></rich-text>
                </view>
              </scroll-view>
            </view>

            <view
              wx:for="{{sections}}"
              wx:key="key"
              wx:for-item="section"
              id="detail-section-{{index}}"
              class="article-section-anchor"
            >
              <detail-section-renderer
                section="{{section}}"
                zoomActive="{{zoomActive}}"
                bind:mathimagelongpress="onSectionMathImageLongPress"
                bind:textlongpress="onTextLongPress"
              ></detail-section-renderer>
            </view>
          </view>
        </view>
      </scroll-view>

      <view wx:if="{{zoomActive}}" class="zoom-hint">
        双指缩放，单指拖动
      </view>
    </view>
  </view>

  <view wx:if="{{copyToastVisible}}" class="copy-feedback" catchtap="noop">
    <view class="copy-feedback-label">{{copyToastTitle}}</view>
    <view wx:if="{{copyToastText}}" class="copy-feedback-text">{{copyToastText}}</view>
  </view>

  <view wx:if="{{textCopyPanelVisible}}" class="text-selection-toolbar">
    <view class="text-selection-action" bindtap="onTextSelectionCopyTap">复制</view>
    <view class="text-selection-divider"></view>
    <view class="text-selection-action" bindtap="onTextSelectionSelectAllTap">全选</view>
  </view>

  <view
    wx:if="{{textCopyPanelVisible}}"
    class="text-copy-dismiss-layer"
    bindtap="onTextCopyReselectTap"
  ></view>

  <view
    wx:if="{{textCopyPanelVisible}}"
    class="text-copy-panel"
    catchtap="noop"
  >
    <view class="text-copy-panel-head">
      <view class="text-copy-title-row">
        <view class="text-copy-title">编辑后复制</view>
      </view>
      <view class="text-copy-restore" bindtap="onTextCopyResetTap">恢复原文</view>
    </view>
    <view class="text-copy-hint">可修改选中文本，再点击复制</view>
    <textarea
      class="text-copy-editor"
      value="{{textCopyDraftText}}"
      maxlength="-1"
      auto-height="{{true}}"
      cursor-spacing="24"
      bindinput="onTextCopyDraftInput"
    ></textarea>
    <view class="text-copy-actions">
      <button class="text-copy-btn text-copy-btn-ghost" bindtap="onTextCopyReselectTap">
        重新选择
      </button>
      <button class="text-copy-btn text-copy-btn-ghost" bindtap="onTextCopyClearTap">
        清空
      </button>
      <button class="text-copy-btn text-copy-btn-primary" bindtap="onTextCopyPanelCopyTap">
        复制
      </button>
    </view>
  </view>

  <view wx:if="{{viewState === 'content'}}" class="bottom-action-shell">
    <view class="bottom-navigation-row">
      <button
        bindtap="onPreviousDetailTap"
        class="bottom-action-btn bottom-navigation-btn bottom-navigation-prev"
        loading="{{detailNavigationBusy && detailNavigationDirection === 'prev'}}"
        disabled="{{detailNavigationBusy}}"
      >
        上一篇
      </button>
      <button
        bindtap="onNextDetailTap"
        class="bottom-action-btn bottom-navigation-btn bottom-navigation-next"
        loading="{{detailNavigationBusy && detailNavigationDirection === 'next'}}"
        disabled="{{detailNavigationBusy}}"
      >
        下一篇
      </button>
    </view>

    <view class="bottom-action-row">
      <button
        bindtap="handleFavoriteToggleTap"
        class="bottom-action-btn bottom-action-favorite {{isFavorited ? 'bottom-action-favorite-active' : 'bottom-action-favorite-inactive'}}"
        loading="{{favoriteActionBusy}}"
        disabled="{{favoriteActionBusy}}"
      >
        {{favoriteActionBusy ? '处理中...' : (isFavorited ? '已收藏' : '收藏')}}
      </button>
      <button class="bottom-action-btn bottom-action-share" open-type="share">
        分享
      </button>
      <button
        bindtap="onDownloadPdfTap"
        class="bottom-action-btn bottom-action-pdf {{pdfActionBusy ? 'bottom-action-pdf-busy' : ''}}"
        loading="{{pdfActionBusy || isDownloadingPdf}}"
        disabled="{{pdfActionBusy || isDownloadingPdf || isUnlockingPdfEntitlement}}"
      >
        {{pdfActionBusy ? pdfActionLabel : '查看高清 PDF'}}
      </button>
    </view>
  </view>

  <view
    wx:if="{{correctionPanelVisible}}"
    class="correction-layer"
    bindtap="onCorrectionCancelTap"
    catchtouchmove="noop"
  >
    <view class="correction-panel" catchtap="noop">
      <view class="correction-drag"></view>
      <view class="correction-head">
        <view class="correction-title">勘误反馈</view>
        <view class="correction-close" bindtap="onCorrectionCancelTap">×</view>
      </view>

      <view class="correction-context">
        <view class="correction-context-row">
          <text class="correction-context-label">结论ID</text>
          <text class="correction-context-value">{{id}}</text>
        </view>
        <view class="correction-context-row">
          <text class="correction-context-label">结论标题</text>
          <text class="correction-context-value">{{title}}</text>
        </view>
      </view>

      <view class="correction-field">
        <view class="correction-label">错误位置</view>
        <view class="correction-selector" bindtap="onCorrectionLocationSelectorTap">
          <text>{{correctionLocationLabel}}</text>
          <text class="correction-selector-arrow">></text>
        </view>
      </view>

      <view class="correction-field">
        <view class="correction-label">错误类型</view>
        <view class="correction-type-list">
          <view
            wx:for="{{correctionTypeOptions}}"
            wx:key="value"
            wx:for-item="option"
            class="correction-type-chip {{correctionType === option.value ? 'is-active' : ''}}"
            data-value="{{option.value}}"
            bindtap="onCorrectionTypeTap"
          >
            {{option.label}}
          </view>
        </view>
      </view>

      <view class="correction-field">
        <view class="correction-label">问题描述</view>
        <textarea
          class="correction-textarea"
          value="{{correctionDescription}}"
          maxlength="{{correctionDescriptionMaxLength}}"
          placeholder="请简要说明你发现的问题..."
          cursor-spacing="24"
          bindinput="onCorrectionDescriptionInput"
        ></textarea>
        <view class="correction-counter">
          {{correctionDescriptionLength}}/{{correctionDescriptionMaxLength}}
        </view>
      </view>

      <button
        class="correction-submit"
        loading="{{correctionSubmitting}}"
        disabled="{{correctionSubmitting}}"
        bindtap="onCorrectionSubmitTap"
      >
        {{correctionSubmitting ? '提交中...' : '提交反馈'}}
      </button>
    </view>
  </view>

  <view
    wx:if="{{pdfStatus.visible}}"
    class="pdf-status-layer"
    catchtap="onPdfStatusMaskTap"
    catchtouchmove="noop"
  >
    <view class="pdf-status-card pdf-status-card-{{pdfStatus.tone}}" catchtap="noop">
      <view class="pdf-status-head">
        <view class="pdf-status-stage">{{pdfStatus.stageLabel}}</view>
        <view wx:if="{{pdfStatus.progressText}}" class="pdf-status-percent">
          {{pdfStatus.progressText}}
        </view>
      </view>

      <view class="pdf-status-title">{{pdfStatus.title}}</view>
      <view class="pdf-status-message">{{pdfStatus.message}}</view>

      <view wx:if="{{pdfStatus.showProgress}}" class="pdf-progress-track">
        <view class="pdf-progress-fill" style="width: {{pdfStatus.progress}}%;"></view>
      </view>

      <view class="pdf-status-foot">
        <view class="pdf-status-dot pdf-status-dot-{{pdfStatus.tone}}">
          <view wx:if="{{pdfActionBusy}}" class="pdf-status-spinner"></view>
          <view wx:elif="{{pdfStatus.tone === 'success'}}" class="pdf-status-check">✓</view>
          <view wx:else class="pdf-status-dot-core"></view>
        </view>

        <view wx:if="{{pdfStatus.canRetry}}" class="pdf-status-actions">
          <button class="pdf-status-btn pdf-status-btn-primary" bindtap="onRetryOpenPdf">
            重试
          </button>
          <button class="pdf-status-btn pdf-status-btn-ghost" bindtap="dismissPdfStatus">
            关闭
          </button>
        </view>

        <view wx:elif="{{pdfStatus.tone === 'success'}}" class="pdf-status-hint">
          已完成，可继续查看
        </view>

        <view wx:else class="pdf-status-hint">
          {{pdfActionBusy ? '请稍候，不要离开当前页面' : '点击空白处关闭'}}
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{enablePdfEntitlementFlow && isUnlockModalVisible}}"
    class="pdf-unlock-layer"
    catchtap="onPdfUnlockMaskTap"
    catchtouchmove="noop"
  >
    <view class="pdf-unlock-card" catchtap="noop">
      <view class="pdf-unlock-title">开启高清 PDF 下载权益</view>
      <view class="pdf-unlock-desc">内容可免费查看，PDF 下载需开启权益。</view>
      <view class="pdf-unlock-desc">看一次视频，2 小时内可下载 PDF。</view>
      <view class="pdf-unlock-hint">适合离线查看、打印整理。</view>

      <button
        class="pdf-unlock-btn pdf-unlock-btn-primary"
        loading="{{isUnlockingPdfEntitlement}}"
        disabled="{{isUnlockingPdfEntitlement}}"
        bindtap="onUnlockPdfConfirmTap"
      >
        {{isUnlockingPdfEntitlement ? '解锁中...' : '看视频解锁'}}
      </button>
      <button
        class="pdf-unlock-btn pdf-unlock-btn-ghost"
        disabled="{{isUnlockingPdfEntitlement}}"
        bindtap="onUnlockPdfLaterTap"
      >
        暂不需要
      </button>
    </view>
  </view>

  <auth-status-toast-host
    visible="{{authStatusToastVisible}}"
    type="{{authStatusToastType}}"
    title="{{authStatusToastTitle}}"
    message="{{authStatusToastMessage}}"
    retryable="{{authStatusToastRetryable}}"
    closable="{{authStatusToastClosable}}"
    bindretry="handleAuthStatusRetryTap"
    bindclose="handleAuthStatusCloseTap"
  ></auth-status-toast-host>
</view>
