<view class="page">
  <navigation-bar
    back="{{showBackButton}}"
    homeButton="{{showHomeButton}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="toolbar">
    <view class="toolbar-main">
      <view class="toolbar-title" bindlongpress="onTitleLongPress">{{title}}</view>
      <view class="toolbar-sub">
        <text>{{category}}</text>
        <view class="toolbar-chip toolbar-id">ID {{id}}</view>
        <view wx:if="{{viewState === 'content' && loadDurationLabel}}" class="toolbar-chip toolbar-load-time">
          {{loadDurationLabel}}
        </view>
        <view class="toolbar-chip toolbar-scale">{{scaleLabel}}</view>
      </view>
    </view>

    <view class="toolbar-actions">
      <button bindtap="onToggleZoom" class="toolbar-btn">
        {{zoomActive ? '退出缩放' : '缩放阅读'}}
      </button>
    </view>
  </view>

  <view class="viewer">
    <view wx:if="{{viewState === 'loading'}}" class="state-card">
      <view class="state-title">正在加载</view>
      <view class="state-desc">{{viewMessage || '请稍候...'}}</view>
    </view>

    <view wx:elif="{{viewState === 'error'}}" class="state-card">
      <view class="state-title">加载失败</view>
      <view class="state-desc">{{viewMessage || '网络异常，请稍后重试'}}</view>
      <button class="state-btn" bindtap="onRetryLoad">重试</button>
    </view>

    <view wx:elif="{{viewState === 'empty'}}" class="state-card">
      <view class="state-title">暂无内容</view>
      <view class="state-desc">{{viewMessage || '当前结论没有可展示信息'}}</view>
    </view>

    <view
      wx:else
      class="viewer-content"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    >
      <scroll-view
        class="article-scroll"
        scroll-y="{{!zoomActive}}"
        scroll-top="{{articleScrollTop}}"
        enhanced="{{true}}"
        show-scrollbar="{{false}}"
        bindscroll="onArticleScroll"
      >
        <view
          id="articleWrapper"
          class="article-wrapper"
          style="{{transformStyle}}"
        >
          <view class="article-card">
            <view class="article-header">
              <view class="article-eyebrow">{{category}}</view>
              <view class="article-id">条目 ID: {{id}}</view>
              <view class="article-title" bindlongpress="onTitleLongPress">{{title}}</view>
              <view wx:if="{{summaryHtml}}" class="article-summary rich-copy">
                <rich-text nodes="{{summaryHtml}}"></rich-text>
              </view>
              <view wx:elif="{{summary}}" class="article-summary">
                {{summary}}
              </view>

              <view
                wx:if="{{hasDifficulty || showFavoriteStatus || (tags && tags.length)}}"
                class="article-meta-chips"
              >
                <view wx:if="{{hasDifficulty}}" class="meta-chip meta-chip-difficulty">
                  难度 {{difficultyLabel}}
                </view>

                <view
                  wx:if="{{showFavoriteStatus}}"
                  class="meta-chip {{isFavorited ? 'meta-chip-favorited' : 'meta-chip-unfavorited'}}"
                >
                  {{favoriteStatusText}}
                </view>

                <view wx:for="{{tags}}" wx:key="*this" wx:for-item="tag" class="meta-chip">
                  {{tag}}
                </view>
              </view>

              <view wx:if="{{aliasesDisplay}}" class="article-alias">
                别名：{{aliasesDisplay}}
              </view>
            </view>

            <view wx:if="{{coreFormulaImage || coreFormulaHtml}}" class="hero-formula">
              <view wx:if="{{coreFormulaImage}}" class="math-image-block hero-math-image-block">
                <scroll-view
                  scroll-x
                  enhanced="{{true}}"
                  show-scrollbar="{{false}}"
                  class="math-image-scroll"
                >
                  <image
                    wx:if="{{coreFormulaImage.imageUrl && !coreFormulaImage.imageLoadFailed}}"
                    class="math-image"
                    src="{{coreFormulaImage.imageUrl}}"
                    mode="widthFix"
                    lazy-load="{{true}}"
                    style="width: {{coreFormulaImage.displayWidthRpx}}rpx;"
                    data-url="{{coreFormulaImage.imageUrl}}"
                    binderror="onCoreFormulaImageError"
                    bindlongpress="onCoreFormulaImageLongPress"
                  />
                </scroll-view>

                <view
                  wx:if="{{!coreFormulaImage.imageUrl || coreFormulaImage.imageLoadFailed}}"
                  class="math-image-fallback"
                >
                  <text class="math-image-fallback-title">公式图片暂时无法显示</text>
                  <text wx:if="{{coreFormulaImage.alt}}" class="math-image-fallback-alt">
                    {{coreFormulaImage.alt}}
                  </text>
                </view>
              </view>

              <scroll-view wx:else scroll-x="{{!zoomActive}}" class="formula-scroll" enhanced="{{true}}">
                <view class="formula-track">
                  <rich-text class="formula-rich" nodes="{{coreFormulaHtml}}"></rich-text>
                </view>
              </scroll-view>
            </view>

            <detail-section-renderer
              wx:for="{{sections}}"
              wx:key="key"
              wx:for-item="section"
              section="{{section}}"
              zoomActive="{{zoomActive}}"
              bind:mathimagelongpress="onSectionMathImageLongPress"
            ></detail-section-renderer>
          </view>
        </view>
      </scroll-view>

      <view wx:if="{{zoomActive}}" class="zoom-hint">
        双指缩放，单指拖动
      </view>
    </view>
  </view>

  <view wx:if="{{copyToastVisible}}" class="copy-feedback" catchtap="noop">
    <view class="copy-feedback-label">已复制</view>
    <view class="copy-feedback-text">{{copyToastText}}</view>
  </view>

  <view wx:if="{{viewState === 'content'}}" class="bottom-action-shell">
    <view class="bottom-action-row">
      <button
        bindtap="handleFavoriteToggleTap"
        class="bottom-action-btn bottom-action-favorite {{isFavorited ? 'bottom-action-favorite-active' : 'bottom-action-favorite-inactive'}}"
        loading="{{favoriteActionBusy}}"
        disabled="{{favoriteActionBusy}}"
      >
        {{favoriteActionBusy ? '处理中...' : (isFavorited ? '已收藏' : '收藏')}}
      </button>
      <button class="bottom-action-btn bottom-action-share" open-type="share">
        分享
      </button>
      <button
        bindtap="onDownloadPdfTap"
        class="bottom-action-btn bottom-action-pdf {{pdfActionBusy ? 'bottom-action-pdf-busy' : ''}}"
        loading="{{pdfActionBusy || isDownloadingPdf}}"
        disabled="{{pdfActionBusy || isDownloadingPdf || isUnlockingPdfEntitlement}}"
      >
        {{pdfActionBusy ? pdfActionLabel : '查看高清 PDF'}}
      </button>
    </view>
  </view>

  <view
    wx:if="{{pdfStatus.visible}}"
    class="pdf-status-layer"
    catchtap="onPdfStatusMaskTap"
    catchtouchmove="noop"
  >
    <view class="pdf-status-card pdf-status-card-{{pdfStatus.tone}}" catchtap="noop">
      <view class="pdf-status-head">
        <view class="pdf-status-stage">{{pdfStatus.stageLabel}}</view>
        <view wx:if="{{pdfStatus.progressText}}" class="pdf-status-percent">
          {{pdfStatus.progressText}}
        </view>
      </view>

      <view class="pdf-status-title">{{pdfStatus.title}}</view>
      <view class="pdf-status-message">{{pdfStatus.message}}</view>

      <view wx:if="{{pdfStatus.showProgress}}" class="pdf-progress-track">
        <view class="pdf-progress-fill" style="width: {{pdfStatus.progress}}%;"></view>
      </view>

      <view class="pdf-status-foot">
        <view class="pdf-status-dot pdf-status-dot-{{pdfStatus.tone}}">
          <view wx:if="{{pdfActionBusy}}" class="pdf-status-spinner"></view>
          <view wx:elif="{{pdfStatus.tone === 'success'}}" class="pdf-status-check">✓</view>
          <view wx:else class="pdf-status-dot-core"></view>
        </view>

        <view wx:if="{{pdfStatus.canRetry}}" class="pdf-status-actions">
          <button class="pdf-status-btn pdf-status-btn-primary" bindtap="onRetryOpenPdf">
            重试
          </button>
          <button class="pdf-status-btn pdf-status-btn-ghost" bindtap="dismissPdfStatus">
            关闭
          </button>
        </view>

        <view wx:elif="{{pdfStatus.tone === 'success'}}" class="pdf-status-hint">
          已完成，可继续查看
        </view>

        <view wx:else class="pdf-status-hint">
          {{pdfActionBusy ? '请稍候，不要离开当前页面' : '点击空白处关闭'}}
        </view>
      </view>
    </view>
  </view>

  <view
    wx:if="{{enablePdfEntitlementFlow && isUnlockModalVisible}}"
    class="pdf-unlock-layer"
    catchtap="onPdfUnlockMaskTap"
    catchtouchmove="noop"
  >
    <view class="pdf-unlock-card" catchtap="noop">
      <view class="pdf-unlock-title">开启高清 PDF 下载权益</view>
      <view class="pdf-unlock-desc">内容可免费查看，PDF 下载需开启权益。</view>
      <view class="pdf-unlock-desc">看一次视频，2 小时内可下载 PDF。</view>
      <view class="pdf-unlock-hint">适合离线查看、打印整理。</view>

      <button
        class="pdf-unlock-btn pdf-unlock-btn-primary"
        loading="{{isUnlockingPdfEntitlement}}"
        disabled="{{isUnlockingPdfEntitlement}}"
        bindtap="onUnlockPdfConfirmTap"
      >
        {{isUnlockingPdfEntitlement ? '解锁中...' : '看视频解锁'}}
      </button>
      <button
        class="pdf-unlock-btn pdf-unlock-btn-ghost"
        disabled="{{isUnlockingPdfEntitlement}}"
        bindtap="onUnlockPdfLaterTap"
      >
        暂不需要
      </button>
    </view>
  </view>

  <auth-status-toast-host
    visible="{{authStatusToastVisible}}"
    type="{{authStatusToastType}}"
    title="{{authStatusToastTitle}}"
    message="{{authStatusToastMessage}}"
    retryable="{{authStatusToastRetryable}}"
    closable="{{authStatusToastClosable}}"
    bindretry="handleAuthStatusRetryTap"
    bindclose="handleAuthStatusCloseTap"
  ></auth-status-toast-host>
</view>
