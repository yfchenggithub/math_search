<scroll-view
  scroll-y
  class="page"
  enhanced
  show-scrollbar="false"
>
  <view class="container">
    <view
      class="viewer"
      catchtouchstart="onTouchStart"
      catchtouchmove="onTouchMove"
      catchtouchend="onTouchEnd"
    >
      <!-- SVG 容器（可换成 inline svg 或 rich-text） -->
      <view
        id="svgWrapper"
        class="svg-wrapper"
        style="{{transformStyle}}"
      >
        <image
          src="{{svgUrl}}"
          mode="aspectFit"
          class="svg-image"
        />
      </view>
    </view>
  </view>
</scroll-view>