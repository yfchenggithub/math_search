<view class="page">
  <!-- 内容（占满） -->
  <view
    class="viewer"
    catchtouchstart="onTouchStart"
    catchtouchmove="onTouchMove"
    catchtouchend="onTouchEnd"
  >
    <view
      id="svgWrapper"
      class="svg-wrapper"
      style="{{transformStyle}}"
    >
      <image
        src="{{svgUrl}}"
        mode="widthFix"
        class="svg-image"
      />
    </view>
  </view>

  <view>
    <button bindtap="openPdf" class="pdf-btn">
      查看高清PDF
    </button>
  </view>

</view>