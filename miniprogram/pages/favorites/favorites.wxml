<view class="favorites-page">
  <navigation-bar
    title="我的收藏"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="favorites-page__container">
    <view class="favorites-handout-card">
      <view class="favorites-handout-card__header">
        <text class="favorites-handout-card__title">收藏讲义</text>
        <text class="favorites-handout-card__badge">最多 {{favoriteHandoutMaxCount}} 条 / 1 份 PDF</text>
      </view>

      <text class="favorites-handout-card__desc">
        将当前收藏内容整理为一份 PDF，方便打印和分享
      </text>

      <view
        wx:if="{{handoutStatusMessage}}"
        class="favorites-handout-card__status favorites-handout-card__status--{{handoutStatusType}}"
      >
        <view
          wx:if="{{handoutStatusType === 'loading'}}"
          class="favorites-handout-card__status-spinner"
        ></view>
        <text class="favorites-handout-card__status-text">{{handoutStatusMessage}}</text>
      </view>

      <view class="favorites-handout-card__footer">
        <view class="favorites-handout-card__count-block">
          <text class="favorites-handout-card__count-label">已收藏</text>
          <view class="favorites-handout-card__count-row">
            <text class="favorites-handout-card__count">{{favoriteCount}}</text>
            <text class="favorites-handout-card__unit">条</text>
          </view>
        </view>

        <button
          class="favorites-handout-card__action {{(favoriteCount <= 0 || favoriteCount > favoriteHandoutMaxCount || pageStatus === 'loading' || pageStatus === 'guest' || isGeneratingHandout) ? 'favorites-handout-card__action--disabled' : ''}}"
          bindtap="handleGenerateFavoriteHandoutTap"
          loading="{{isGeneratingHandout}}"
          disabled="{{isGeneratingHandout}}"
        >
          <view
            wx:if="{{!isGeneratingHandout}}"
            class="favorites-handout-card__action-icon"
          ></view>
          <text class="favorites-handout-card__action-text">
            {{isGeneratingHandout ? '正在生成讲义…' : (favoriteCount > favoriteHandoutMaxCount ? handoutLimitActionText : '生成收藏讲义')}}
          </text>
        </button>
      </view>
    </view>

    <view class="favorites-list-section">
      <view class="favorites-list-section__title">收藏内容</view>

      <view wx:if="{{pageStatus === 'loading'}}" class="favorites-state-card">
        <text class="favorites-state-card__title">正在加载收藏内容...</text>
      </view>

      <view wx:elif="{{pageStatus === 'ready'}}" class="favorites-list-section__list">
        <conclusion-card
          wx:for="{{favoriteItems}}"
          wx:key="id"
          item-id="{{item.id}}"
          title="{{item.title}}"
          summary="{{item.summary}}"
          tags="{{item.tags}}"
          module="{{item.module}}"
          entry="favorites_card"
          section="favorites"
          updated-at="{{item.updatedAt}}"
          preview-type="{{item.previewType}}"
          preview-html="{{item.previewHtml}}"
          preview-text="{{item.previewText}}"
          preview-image="{{item.previewImage}}"
          preview-image-width="{{item.previewImageWidth}}"
          preview-image-height="{{item.previewImageHeight}}"
          preview-fallback-text="{{item.previewFallbackText}}"
          bind:cardtap="handleFavoriteCardTap"
          bind:cardlongpress="handleFavoriteCardLongPress"
        ></conclusion-card>
      </view>

      <view wx:elif="{{pageStatus === 'empty'}}" class="favorites-state-card">
        <text class="favorites-state-card__title">还没有收藏内容</text>
        <text class="favorites-state-card__desc">
          遇到有价值的结论时，可以先收藏，方便以后快速查看。
        </text>
        <button class="favorites-state-card__action" bindtap="handleGoSearchTap">
          去搜索结论
        </button>
      </view>

      <view wx:elif="{{pageStatus === 'error'}}" class="favorites-state-card">
        <text class="favorites-state-card__title">收藏内容加载失败</text>
        <text class="favorites-state-card__desc">请检查网络后重试</text>
        <button class="favorites-state-card__action" bindtap="handleRetryTap">
          重新加载
        </button>
      </view>

      <view wx:elif="{{pageStatus === 'guest'}}" class="favorites-state-card">
        <text class="favorites-state-card__title">登录后查看收藏</text>
        <text class="favorites-state-card__desc">
          收藏的结论会保存在你的账号中
        </text>
        <button class="favorites-state-card__action" bindtap="handleLoginTap">
          登录并查看
        </button>
      </view>
    </view>
  </view>
</view>
