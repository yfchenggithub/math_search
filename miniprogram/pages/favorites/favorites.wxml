<view class="favorites-page">
  <navigation-bar
    title="我的收藏"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="favorites-page__container">
    <view class="favorites-overview-card">
      <view class="favorites-overview-card__left">
        <text class="favorites-overview-card__label">已收藏</text>
        <view class="favorites-overview-card__count-row">
          <text class="favorites-overview-card__count">{{favoriteCount}}</text>
          <text class="favorites-overview-card__unit">条</text>
        </view>
      </view>

      <button
        class="favorites-overview-card__export-btn"
        bindtap="handleExportAllPdfTap"
      >
        <view class="favorites-overview-card__export-icon"></view>
        <text class="favorites-overview-card__export-text">导出全部 PDF</text>
      </button>
    </view>

    <view class="favorites-list-section">
      <view class="favorites-list-section__title">收藏内容</view>
      <view class="favorites-list-section__list">
        <conclusion-card
          wx:for="{{favoriteItems}}"
          wx:key="id"
          item-id="{{item.id}}"
          title="{{item.title}}"
          summary="{{item.summary}}"
          tags="{{item.tags}}"
          module="{{item.module}}"
          entry="favorites_card"
          section="favorites"
          bind:cardtap="handleFavoriteCardTap"
        ></conclusion-card>
      </view>
    </view>
  </view>
</view>
