<view class="favorites-page">
  <navigation-bar
    title="我的收藏"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
  ></navigation-bar>

  <view class="favorites-page__container">
    <view class="favorites-overview-card">
      <view class="favorites-overview-card__left">
        <text class="favorites-overview-card__label">已收藏</text>
        <view class="favorites-overview-card__count-row">
          <text class="favorites-overview-card__count">
            {{favoriteCountLoaded ? favoriteCount : '--'}}
          </text>
          <text wx:if="{{favoriteCountLoaded}}" class="favorites-overview-card__unit">
            条
          </text>
        </view>
      </view>

      <button
        class="favorites-overview-card__export-btn"
        bindtap="handleExportAllPdfTap"
      >
        <view class="favorites-overview-card__export-icon"></view>
        <text class="favorites-overview-card__export-text">导出全部 PDF</text>
      </button>
    </view>

    <view class="favorites-list-section">
      <view class="favorites-list-section__title">收藏内容</view>

      <view wx:if="{{isLoading}}" class="favorites-state-card">
        <text class="favorites-state-card__title">正在加载收藏内容...</text>
      </view>

      <view wx:elif="{{loadErrorMessage}}" class="favorites-state-card">
        <text class="favorites-state-card__title">加载失败</text>
        <text class="favorites-state-card__desc">{{loadErrorMessage}}</text>
        <button class="favorites-state-card__action" bindtap="handleRetryTap">
          重试
        </button>
      </view>

      <view wx:elif="{{isLoginRequired}}" class="favorites-state-card">
        <text class="favorites-state-card__title">登录后可查看收藏内容</text>
        <button class="favorites-state-card__action" bindtap="handleLoginTap">
          去登录
        </button>
      </view>

      <view wx:elif="{{favoriteItems.length > 0}}" class="favorites-list-section__list">
        <conclusion-card
          wx:for="{{favoriteItems}}"
          wx:key="id"
          item-id="{{item.id}}"
          title="{{item.title}}"
          summary="{{item.summary}}"
          tags="{{item.tags}}"
          module="{{item.module}}"
          entry="favorites_card"
          section="favorites"
          bind:cardtap="handleFavoriteCardTap"
        ></conclusion-card>
      </view>

      <view wx:else class="favorites-state-card favorites-state-card--empty">
        <text class="favorites-state-card__title">暂无收藏内容</text>
      </view>
    </view>
  </view>
</view>
