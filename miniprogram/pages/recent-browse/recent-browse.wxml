<view class="page">
  <navigation-bar
    title="{{copy.title}}"
    back="{{true}}"
    fixed="{{true}}"
    placeholder="{{true}}"
    bind:back="handleBackTap"
  ></navigation-bar>

  <view class="header">
    <view class="header-row">
      <view class="title">{{copy.title}}</view>
      <view
        wx:if="{{hasData}}"
        class="header-action"
        hover-class="header-action--active"
        hover-stay-time="80"
        bindtap="handleClearTap"
      >
        <text class="header-action__text">清空记录</text>
      </view>
    </view>
    <view class="sub">{{copy.subtitle}}</view>
  </view>

  <scroll-view scroll-y class="list">
    <view wx:if="{{isLoading}}" class="state-box state-loading">
      加载中...
    </view>

    <block wx:elif="{{hasData}}">
      <view class="recommend-section">
        <block wx:for="{{recentBrowseList}}" wx:key="id">
          <conclusion-card
            item-id="{{item.id}}"
            title="{{item.title}}"
            summary="{{item.summary}}"
            tags="{{item.tags}}"
            module="{{item.module}}"
            entry="recent_browse_card"
            preview-type="{{item.previewType}}"
            preview-html="{{item.previewHtml}}"
            preview-text="{{item.previewText}}"
            preview-image="{{item.previewImage}}"
            preview-fallback-text="{{item.previewFallbackText}}"
            bind:cardtap="handleDetailTap"
          ></conclusion-card>
        </block>
      </view>
    </block>

    <view wx:else class="empty-state">
      <view class="empty-title">{{copy.emptyTitle}}</view>
      <view class="empty-subtitle">{{copy.emptySubtitle}}</view>
    </view>
  </scroll-view>
</view>
